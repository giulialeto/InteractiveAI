# Copy this file to .env and fill in the values
USER_ID=1000
USER_GID=1000
CONFIG_PATH=./
SPRING_PROFILES_ACTIVE=docker
HOST_IP=172.17.0.1

# RL agent API for PowerGrid recommendations
RL_AGENT_API_URL=https://interactiveagent.passerelle.irt-systemx.fr/api/v1/recommendation
RL_AGENT_API_TOKEN=

# VITE build-time variables (also required in frontend/env/.env.local for local dev)
VITE_POWERGRID_SIMU=false
VITE_ATM_SIMU=false
VITE_RAILWAY_SIMU=false
